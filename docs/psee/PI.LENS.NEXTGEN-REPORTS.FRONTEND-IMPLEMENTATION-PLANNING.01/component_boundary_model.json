{
  "schema_version": "1.0",
  "stream": "PI.LENS.NEXTGEN-REPORTS.FRONTEND-IMPLEMENTATION-PLANNING.01",
  "authority": "FRONTEND_IMPLEMENTATION_PLAN.md; PROFESSIONAL_UI_ARCHITECTURE.md; EVIDENCE_PANEL_ARCHITECTURE.md",
  "baseline_ref": "governed-dpsig-baseline-v1",
  "issued": "2026-05-08",
  "description": "Machine-readable component boundary model for LENS NextGen frontend implementation. Defines 16 component families with allowed inputs, forbidden inputs, allowed state, forbidden state, and governance constraints.",
  "governance_note": "All components receive adapter output only. No component may receive raw report_object fields directly. No component may call AI, RAG, or any external intelligence service. Display state only.",

  "universal_forbidden_behaviors": [
    "call_ai_service",
    "call_rag_service",
    "recompute_readiness_state",
    "reinterpret_qualifier_class",
    "supplement_missing_evidence",
    "modify_report_object_fields",
    "expose_raw_geios_identifiers",
    "expose_raw_signal_keys",
    "expose_raw_topology_ids",
    "render_free_form_input",
    "render_ai_assistant_avatar",
    "render_probabilistic_confidence_gauge",
    "suppress_qualifier_when_active",
    "silently_degrade_blocked_state",
    "silently_degrade_diagnostic_state",
    "mutate_topology",
    "elevate_audience_tier_at_runtime"
  ],

  "component_families": {

    "ReportContainer": {
      "family": "ReportContainer",
      "purpose": "Root container. Validates report_object, routes to blocked/diagnostic/normal path, composes all rendering regions from adapter outputs.",
      "file_path": "app/execlens-demo/components/nextgen/ReportContainer.jsx",
      "allowed_inputs": {
        "report_object": "validated report_object (post-schema validation)",
        "audience_tier": "EXECUTIVE | ADVISORY | AUDIT (from session — immutable after init)",
        "validation_result": "output of ReportObjectValidator"
      },
      "forbidden_inputs": [
        "raw API response without validation",
        "AI-generated content",
        "user-modified report fields"
      ],
      "allowed_state": [
        "density_class (derived from audience_tier; immutable after init)",
        "render_route (NORMAL | BLOCKED | DIAGNOSTIC — derived from validation_result)"
      ],
      "forbidden_state": [
        "computed readiness state",
        "modified qualifier",
        "supplemented evidence"
      ],
      "governance_routing": {
        "if_hash_fail": "render BlockedState for all intelligence regions",
        "if_governance_verdict_fail": "render BlockedState for readiness module",
        "if_diagnostic": "render DiagnosticState banner + normal module tree",
        "if_valid": "render normal module tree"
      },
      "rendering_dependencies": ["ExecutiveHeader", "DiagnosticState", "IntelligenceSummary", "EvidencePanel", "TopologySummary", "AuditLineage"],
      "phase_2_status": "ACTIVE",
      "governance_constraints": ["FIP-GOV-01", "FIP-GOV-02", "FIP-GOV-06", "FIP-GOV-10"]
    },

    "ExecutiveHeader": {
      "family": "ExecutiveHeader",
      "purpose": "Renders REGION_EXECUTIVE_HEADER. Contains readiness badge, qualifier chip, scope indicator, report identity, timestamp. Always visible; never collapsible.",
      "file_path": "app/execlens-demo/components/nextgen/ExecutiveHeader.jsx",
      "allowed_inputs": {
        "readiness_badge_display": "output of ReadinessBadgeAdapter",
        "qualifier_chip_display": "output of QualifierChipAdapter",
        "scope_indicator": "pre-rendered scope indicator from header_block",
        "report_metadata": "report identity and timestamp from header_block.report_metadata"
      },
      "forbidden_inputs": [
        "raw readiness_state enum",
        "raw qualifier_class enum",
        "raw evidence_object_hash",
        "GEIOS internal identifiers"
      ],
      "allowed_state": "NONE — this component has no mutable state",
      "forbidden_state": ["computed readiness", "user-modified header fields"],
      "governance": {
        "readiness_badge_always_first": true,
        "qualifier_chip_always_visible_if_active": true,
        "cannot_be_collapsed": true,
        "raw_enum_values_forbidden": true
      },
      "rendering_dependencies": ["ReadinessBadge", "QualifierChip"],
      "phase_2_status": "ACTIVE",
      "governance_constraints": ["VIS-READY-01", "VIS-READY-02", "VIS-QUAL-01", "VIS-QUAL-02"]
    },

    "ReadinessBadge": {
      "family": "ReadinessBadge",
      "purpose": "Renders the readiness badge with ALI-03 executive label and design token. Highest visual priority element.",
      "file_path": "app/execlens-demo/components/nextgen/ReadinessBadge.jsx",
      "allowed_inputs": {
        "readiness_label": "ALI-03 normalized executive label (string)",
        "badge_token": "design token identifier (string — from VIS-READY-01 mapping)",
        "governance_status_label": "executive-visible status label (string)",
        "report_scope_label": "scope note for badge sub-label (optional string)"
      },
      "forbidden_inputs": [
        "raw ReadinessState enum values (EXECUTIVE_READY, DIAGNOSTIC_ONLY, etc.)",
