      "rendering_dependencies": [],
      "phase_2_status": "ACTIVE",
      "governance_constraints": ["VIS-READY-01", "VIS-READY-02", "PUI-GOV-03"]
    },

    "QualifierChip": {
      "family": "QualifierChip",
      "purpose": "Renders qualifier chip with Q-taxonomy label and tooltip. Mandatory when qualifier active. Never suppressed. Q-04 renders absence notice.",
      "file_path": "app/execlens-demo/components/nextgen/QualifierChip.jsx",
      "allowed_inputs": {
        "chip_label": "Q-taxonomy chip label (string or null for Q-00)",
        "chip_token": "design token for chip color (string or 'NONE')",
        "tooltip_text": "pre-rendered Q-taxonomy tooltip (string or null)",
        "absence_notice": "absence notice text for Q-04 (string or null)",
        "renders": "boolean — whether chip renders (false for Q-00)"
      },
      "forbidden_inputs": [
        "raw qualifier_class enum (Q-00, Q-01, etc.)",
        "qualifier_class field directly from report_object"
      ],
      "allowed_state": ["tooltip_visible (boolean — hover/focus state)"],
      "forbidden_state": ["modified qualifier class", "suppressed qualifier"],
      "governance": {
        "suppression_prohibited": true,
        "chip_renders_if_renders_is_true": true,
        "q04_absence_notice_mandatory": true,
        "chip_token_from_governance_only": true,
        "tooltip_from_pre_rendered_text_only": true
      },
      "rendering_dependencies": [],
      "phase_2_status": "ACTIVE",
      "governance_constraints": ["VIS-QUAL-01", "VIS-QUAL-02", "EXP-QUAL-01", "EXP-QUAL-02", "EXP-QUAL-03"]
    },

    "IntelligenceSummary": {
      "family": "IntelligenceSummary",
      "purpose": "Renders REGION_INTELLIGENCE_SUMMARY. Contains full executive summary, WHY primary statement, domain evidence summary, propagation summary.",
      "file_path": "app/execlens-demo/components/nextgen/IntelligenceSummary.jsx",
      "allowed_inputs": {
