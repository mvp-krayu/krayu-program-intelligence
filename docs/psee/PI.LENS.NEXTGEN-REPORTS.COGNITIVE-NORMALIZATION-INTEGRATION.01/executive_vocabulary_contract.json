    "forbidden_labels": [
      "AI explanation",
      "Ask AI",
      "AI insights",
      "Model reasoning",
      "How the AI decided"
    ]
  },

  "structural_vocabulary": {
    "description": "Approved terminology for structural topology descriptions.",
    "approved_terms": {
      "execution topology": "The structural organization of execution domains and clusters",
      "execution domain": "[Domain alias] — a named structural boundary",
      "execution cluster": "[Cluster alias] — a structural unit within a domain",
      "pressure concentration": "High cluster pressure in a localized structural area",
      "distribution pattern": "How execution load distributes across downstream clusters",
      "structural bottleneck": "A structural constraint limiting distribution",
      "structural isolation": "A domain with independent pressure patterns"
    },
    "forbidden_terms": [
      "microservice",
      "API",
      "service mesh",
      "repository",
      "codebase",
      "GitHub",
      "JIRA",
      "ticket",
      "sprint",
      "velocity",
      "throughput"
    ],
    "note": "Structural vocabulary must be topology-neutral. Platform-specific terms are forbidden unless they are the client-configured ALI alias."
  },

  "forbidden_vocabulary": {
    "description": "Permanently forbidden vocabulary categories in LENS executive surfaces.",

    "category_A_geios_internals": {
      "description": "GEIOS internal identifiers — never in executive surface",
      "forbidden": [
        "TAXONOMY-01", "signal_value", "activation_state", "signal_stable_key",
        "derivation_hash", "evidence_object_hash",
        "CPI", "CFA", "cpi_score", "cfa_score",
        "DPSIG", "EXSIG", "ORGSIG", "FLOWSIG", "RISKSIG", "TIMSIG", "RUNSIG", "OPSIG",
        "Lane A", "Lane B", "Lane C", "Lane D",
        "L1", "L2", "L3", "L4", "L5", "L6", "L7", "L8", "L9",
        "AS-01", "N-SAF-01", "E-SAF-01", "C-SAF-01", "ES-01", "OS-01",
        "GEIOS", "GEIOS substrate", "GEIOS architecture",
        "canonical_topology.json",
        "governed-dpsig-baseline-v1"
      ]
    },

    "category_B_ai_llm_terms": {
      "description": "AI and LLM internal terminology — never in executive surface",
      "forbidden": [
        "AI", "artificial intelligence", "machine learning", "ML",
        "LLM", "large language model", "language model",
        "prompt", "prompt engineering", "system prompt",
        "token", "context window", "embedding", "vector", "similarity score",
        "RAG", "retrieval-augmented generation", "retrieval",
        "hallucination", "confabulation", "AI error",
        "agent", "multi-agent", "orchestration", "orchestrator",
        "Claude", "GPT", "model name",
        "copilot"
      ],
      "note": "'copilot' is reserved for Phase 5 product terminology — forbidden in Phase 2 executive surface"
    },

    "category_C_predictive_language": {
      "description": "Predictive language — no predictive authority in governed structural derivation",
      "forbidden": [
        "will result in", "will cause", "will lead to",
        "will degrade", "will improve", "will spread",
        "is expected to", "is likely to", "is anticipated to",
        "predicts", "forecasts", "projected", "projection",
        "anticipated outcome", "expected impact"
      ]
    },

    "category_D_recommendation_language": {
      "description": "Recommendation language — reports provide intelligence, not prescriptions",
      "forbidden": [
        "we recommend", "recommendation:", "action item:",
        "you should", "the team should", "they should",
        "must be addressed", "requires immediate attention",
        "action required", "urgent action",
        "please", "fix this", "resolve this", "address this"
      ]
    },

    "category_E_speculative_language": {
      "description": "Speculative language — uncertainty expressed through Q-taxonomy qualifiers only",
      "forbidden": [
        "possibly", "perhaps", "maybe",
        "might indicate", "could suggest", "may represent",
        "our analysis suggests", "we believe", "we think",
        "confidence: [percentage]", "[number]% confidence",
        "unclear", "uncertain", "ambiguous"
      ]
    },

    "category_F_emotional_apologetic_language": {
      "description": "Emotional and apologetic language — scope is factual, not apologetic",
      "forbidden": [
        "unfortunately", "regrettably", "sadly",
        "we apologize", "we're sorry", "we're unable to provide",
        "good news", "bad news", "concerning",
        "alarming", "encouraging", "disappointing"
      ]
    },

    "category_G_consumer_ai_phrasing": {
      "description": "Consumer AI / chatbot phrasing — wrong product category",
      "forbidden": [
        "Sure!", "Certainly!", "Of course!", "Absolutely!",
        "Great question!", "Happy to help!",
        "Let me explain", "Let me tell you",
        "I think", "I believe", "I found", "I see",
        "As an AI", "As a language model",
        "Based on my analysis", "Based on what I know",
        "I'm unable to", "I don't have access to"
      ]
    },

    "category_H_platform_specific_terms": {
      "description": "Platform-specific operational terms — topology is neutral unless client-aliased",
      "forbidden_unless_client_aliased": [
        "microservice", "service", "API endpoint",
        "repository", "repo", "codebase",
        "GitHub", "GitLab", "Jira", "Confluence",
        "sprint", "ticket", "story", "epic",
        "pipeline", "CI/CD", "deployment"
      ]
    }
  }
