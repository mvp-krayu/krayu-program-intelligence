      "EVIDENCE": "Structural Evidence",
      "TRACE": "Analysis Trace",
      "QUALIFIERS": "Evidence Scope",
      "LINEAGE": "Analysis Provenance",
      "CONFIDENCE": "Coverage Confidence",
