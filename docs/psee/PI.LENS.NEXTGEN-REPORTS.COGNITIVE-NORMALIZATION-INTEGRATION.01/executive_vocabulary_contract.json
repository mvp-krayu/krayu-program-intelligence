  "baseline_ref": "governed-dpsig-baseline-v1",
  "issued": "2026-05-08",
  "description": "Formal executive-facing vocabulary contract for LENS NextGen reports. Defines approved executive terminology and permanently forbidden vocabulary categories.",

  "readiness_vocabulary": {
    "description": "Approved executive labels for readiness states. Raw enum values are forbidden in executive surface.",
    "approved_terms": [
      {"source": "EXECUTIVE_READY",                      "executive_label": "Executive Ready",               "qualifier": null},
      {"source": "EXECUTIVE_READY_WITH_QUALIFIER",       "executive_label": "Executive Ready — Qualified",   "qualifier": "Q-01 or Q-02 context"},
      {"source": "DIAGNOSTIC_ONLY",                      "executive_label": "Under Structural Review",       "qualifier": "Q-03 context"},
      {"source": "SUPPRESSED_FROM_EXECUTIVE",            "executive_label": "Not Available",                 "qualifier": "Q-04 context"},
      {"source": "BLOCKED_PENDING_DOMAIN_GROUNDING",     "executive_label": "Pending Grounding",             "qualifier": "grounding scope note"}
    ],
    "forbidden_raw_values": [
      "EXECUTIVE_READY",
      "EXECUTIVE_READY_WITH_QUALIFIER",
      "DIAGNOSTIC_ONLY",
      "SUPPRESSED_FROM_EXECUTIVE",
      "BLOCKED_PENDING_DOMAIN_GROUNDING"
    ]
  },

  "qualifier_vocabulary": {
    "description": "Approved executive labels for qualifier states. Q-class enum values forbidden in executive surface.",
    "approved_terms": [
      {"source": "Q-00", "chip_label": null,               "tooltip": null,                                                                       "scope_note": null},
      {"source": "Q-01", "chip_label": "Partial Grounding","tooltip": "Analysis based on {n} of {total} grounded domains.",                       "scope_note": "Coverage note at end of executive summary"},
      {"source": "Q-02", "chip_label": "Structural View",  "tooltip": "Structural topology confirmed. Semantic depth reflects available grounding.","scope_note": "In CONFIDENCE panel"},
      {"source": "Q-03", "chip_label": "Under Review",     "tooltip": "Advisory confirmation recommended before executive action.",                "scope_note": "Diagnostic frame applied to narrative"},
      {"source": "Q-04", "chip_label": null,               "tooltip": null,                                                                       "scope_note": "Absence notice: Signal intelligence withheld from this view"}
    ],
    "forbidden_raw_values": ["Q-00", "Q-01", "Q-02", "Q-03", "Q-04"],
    "suppression_prohibited": true
  },

  "signal_vocabulary": {
    "description": "Approved executive labels for signal types. Raw signal keys forbidden.",
    "approved_terms": [
      {"source": "cpi_score",           "executive_label": "Cluster Pressure Level",       "configurable": true,  "ali_rule": "NORM-ALI-01"},
      {"source": "cfa_score",           "executive_label": "Fan Distribution Asymmetry",   "configurable": true,  "ali_rule": "NORM-ALI-02"},
      {"source": "HIGH pressure_tier",  "executive_label": "High execution pressure",       "configurable": false, "ali_rule": "NORM-PROP-01"},
      {"source": "ELEVATED",            "executive_label": "Elevated pressure",             "configurable": false, "ali_rule": "NORM-PROP-01"},
      {"source": "MODERATE",            "executive_label": "Moderate pressure",             "configurable": false, "ali_rule": "NORM-PROP-01"},
      {"source": "LOW",                 "executive_label": "Stable / low pressure",         "configurable": false, "ali_rule": "NORM-PROP-01"}
    ],
    "forbidden_raw_values": [
      "cpi_score", "cfa_score", "signal_value", "activation_state",
      "signal_stable_key", "derivation_hash", "CPI", "CFA",
      "cluster_pressure_index", "cluster_fan_asymmetry"
    ],
    "forbidden_numerical_values": true,
    "forbidden_threshold_values": true
  },

  "propagation_vocabulary": {
    "description": "Approved phrasing for structural pressure propagation descriptions.",
    "origin_phrases": [
      "originates in",
      "is concentrated in",
      "emanates from",
      "is the source of execution pressure"
    ],
    "flow_phrases": [
      "flows through",
      "passes through",
      "channels through",
      "propagates through"
    ],
    "destination_phrases": [
      "reaches",
      "affects",
      "places load on",
      "contributes pressure to"
    ],
    "isolation_phrases": [
      "shows independent pressure pattern",
      "is structurally isolated from",
      "does not propagate into"
    ],
    "structural_pattern_phrases": {
      "bottleneck": "structural concentration — concentrated load with constrained distribution",
      "cascade": "cascading pressure from [origin] through [path]",
      "balanced": "balanced structural load distribution",
      "asymmetric": "uneven downstream distribution pattern"
    },
    "forbidden_phrases": [
      "will cascade",
      "will spread",
      "is spreading",
      "accelerating",
      "growing",
      "deteriorating",
      "worsening"
    ]
  },

