      "partial": "Partial Coverage ({n} of {total} domains)",
      "structural_only": "Structural View",
      "diagnostic": "Under Review",
      "suppressed": "Signal intelligence withheld from this view"
    },
    "propagation_role_labels": {
      "ORIGIN": "Origin of Pressure",
      "RECEIVER": "Pressure Receiver",
      "PASS_THROUGH": "Pressure Pass-through",
      "ISOLATED": "Independent Domain"
    },
    "approved_evidence_terms": [
      "structural evidence",
      "confirmed topology",
      "pressure analysis",
      "domain analysis",
      "cluster analysis",
      "distribution pattern",
      "concentration pattern"
    ],
    "forbidden_terms": [
      "AI evidence",
      "machine learning output",
      "model output",
      "inferred evidence",
      "predicted evidence",
      "generated insight"
    ]
  },

  "explainability_vocabulary": {
    "description": "Approved panel labels and terminology for explainability surfaces.",
    "panel_titles": {
