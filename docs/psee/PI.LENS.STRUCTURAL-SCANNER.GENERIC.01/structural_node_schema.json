    "size_bytes": "integer | null — file size in bytes from source_inventory.json; null for directories"
  },

  "node_id_assignment": {
    "rule": "Directories first (sorted lexicographically), then files (sorted lexicographically). Counter starts at 1.",
    "directory_range": "NODE-0001 through NODE-{N_dirs}",
    "file_range": "NODE-{N_dirs+1} through NODE-{N_dirs+N_files}"
  },

  "language_types": [
    "python", "javascript", "typescript", "jsx", "tsx",
    "json", "yaml", "markdown", "shell", "html", "css",
    "toml", "text", "lockfile", "image", "sql",
