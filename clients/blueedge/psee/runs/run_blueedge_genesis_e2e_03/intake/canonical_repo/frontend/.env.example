# ═══════════════════════════════════════════
# Blue Edge Fleet Management — Frontend Config
# Copy to .env and adjust for your environment
# ═══════════════════════════════════════════

# ─── API ───
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_WS_URL=http://localhost:3000

# ─── Map ───
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_DEFAULT_CENTER_LAT=25.2048
VITE_MAP_DEFAULT_CENTER_LNG=55.2708
VITE_MAP_DEFAULT_ZOOM=12

# ─── Features ───
VITE_ENABLE_MOCK_DATA=true       # false in production
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=false

# ─── Branding ───
VITE_APP_NAME=Blue Edge Fleet Management
VITE_APP_VERSION=3.14.0
VITE_PRIMARY_COLOR=#22d3ee
VITE_COMPANY_NAME=Blue Edge Network LLC
