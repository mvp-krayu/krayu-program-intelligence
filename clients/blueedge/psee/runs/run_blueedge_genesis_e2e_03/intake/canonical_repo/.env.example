# ═══════════════════════════════════════════
# Blue Edge Fleet — Docker Compose Environment
# Copy to .env and set production values
# ═══════════════════════════════════════════

NODE_ENV=production
DB_NAME=blueedge_fleet
DB_USER=blueedge
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_PORT=5432
REDIS_PASSWORD=CHANGE_ME_redis_password_here
REDIS_PORT=6379
JWT_SECRET=CHANGE_ME_64_char_random_string_here
JWT_EXPIRES_IN=24h
CORS_ORIGIN=https://fleet.blueedge.ae
WEB_PORT=80
WEB_SSL_PORT=443
LOG_LEVEL=info
