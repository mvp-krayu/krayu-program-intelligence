# ═══════════════════════════════════════════
# Blue Edge Fleet Management — Backend Config
# Copy to .env and fill in production values
# ═══════════════════════════════════════════

# ─── Server ───
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ─── Database (PostgreSQL + TimescaleDB) ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blueedge_fleet
DB_USER=blueedge
DB_PASSWORD=blueedge_secret_2026
DB_SYNCHRONIZE=true          # Set false in production — use migrations
DB_LOGGING=false
DB_SSL=false                 # Set true for cloud databases

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=blueedge_redis_2026
REDIS_TTL=3600               # Default cache TTL in seconds

# ─── JWT Authentication ───
JWT_SECRET=change-this-to-a-64-char-random-string-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ───
CORS_ORIGIN=http://localhost:5173,http://localhost:80
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# ─── Logging ───
LOG_LEVEL=debug              # debug | info | warn | error
LOG_FORMAT=pretty            # pretty | json (use json in production)

# ─── WebSocket ───
WS_PORT=3000                 # Same as HTTP port (Socket.IO)
WS_CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting ───
THROTTLE_TTL=60              # Window in seconds
THROTTLE_LIMIT=100           # Max requests per window

# ─── File Upload ───
UPLOAD_MAX_SIZE=10485760     # 10MB
UPLOAD_DEST=./uploads

# ─── External APIs (optional) ───
# OPENSTREETMAP_API_KEY=
# WEATHER_API_KEY=
# SMS_API_KEY=                # For driver notifications
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASS=

# ─── UAE-Specific ───
DEFAULT_CURRENCY=AED
DEFAULT_TIMEZONE=Asia/Dubai
DEFAULT_LOCALE=en-AE
RTA_API_KEY=                 # RTA Dubai integration
ENOC_API_KEY=                # ENOC fuel station integration
