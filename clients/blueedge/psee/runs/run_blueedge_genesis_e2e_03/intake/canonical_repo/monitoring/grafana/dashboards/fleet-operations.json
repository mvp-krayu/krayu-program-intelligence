{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "rate(blueedge_http_requests_total[5m])",
        "legendFormat": "{{method}} {{path}}"
      }]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{
        "expr": "rate(blueedge_http_5xx_total[5m])",
        "legendFormat": "{{method}} {{path}}"
      }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } } }
    },
    {
      "title": "P99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{
        "expr": "blueedge_http_request_duration_ms{quantile=\"0.99\"}",
        "legendFormat": "{{method}} {{path}}"
      }]
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "blueedge_process_heap_bytes / 1024 / 1024", "legendFormat": "Heap (MB)" },
        { "expr": "blueedge_process_rss_bytes / 1024 / 1024", "legendFormat": "RSS (MB)" }
      ]
    },
    {
      "title": "Cache Performance",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        { "expr": "blueedge_cache_hits_total / (blueedge_cache_hits_total + blueedge_cache_misses_total) * 100", "legendFormat": "Hit Rate %" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      }
    },
    {
      "title": "Cache Connected",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 16 },
      "targets": [{ "expr": "blueedge_cache_connected", "legendFormat": "Redis" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }]
        }
      }
    },
    {
      "title": "Events Emitted",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 16 },
      "targets": [{ "expr": "blueedge_events_total", "legendFormat": "Total Events" }]
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "rate(blueedge_process_cpu_user_seconds[5m])", "legendFormat": "User CPU" },
        { "expr": "rate(blueedge_process_cpu_system_seconds[5m])", "legendFormat": "System CPU" }
      ]
    },
    {
      "title": "Top Endpoints by Latency",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [{
        "expr": "topk(10, blueedge_http_request_duration_ms{quantile=\"0.99\"})",
        "format": "table",
        "instant": true
      }]
    },
    {
      "title": "Request Volume by Endpoint",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [{
        "expr": "topk(10, sum by(path) (rate(blueedge_http_requests_total[5m])))",
        "legendFormat": "{{path}}"
      }]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["blueedge", "fleet", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Dubai",
  "title": "Blue Edge Fleet — Operations Dashboard",
  "uid": "blueedge-fleet-ops",
  "version": 1
}
