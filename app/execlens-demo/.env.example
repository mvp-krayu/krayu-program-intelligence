# ExecLens Demo — Environment Configuration
# PIOS-42.9-RUN01-CONTRACT-v1
#
# Copy this file to .env.local and set values before running.
#
# Usage:
#   cp .env.example .env.local
#   npm run dev

# ---------------------------------------------------------------------------
# NEXT_PUBLIC_OBSIDIAN_VAULT_NAME
#
# Your Obsidian vault name — enables direct deep-link activation for resolved
# architecture notes in the Navigation panel and Topology panel.
#
# How to find your vault name:
#   Open Obsidian → Settings → About → Vault name
#   OR: check the folder name of your vault on disk
#
# For the BlueEdge PIE vault in this repository:
#   The vault is located at: docs/pios/41.2/pie_vault/
#   Register it in Obsidian by opening that folder as a vault.
#   The vault name will be: pie_vault
#
# If empty or unset:
#   Navigation links show file paths only — no deep links rendered.
#   All other functionality is unaffected.
#
# Vault-relative path format (R10 — deterministic):
#   docs/pios/41.2/pie_vault/01_Domains/D_10_X.md
#   → obsidian://open?vault=pie_vault&file=01_Domains/D_10_X
# ---------------------------------------------------------------------------

NEXT_PUBLIC_OBSIDIAN_VAULT_NAME=pie_vault
